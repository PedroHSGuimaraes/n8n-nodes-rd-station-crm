{
  "name": "n8n-nodes-rd-station-crm",
  "version": "2.1.1",
  "description": "n8n community node for RD Station CRM: API v1 (private token) and API v2 (OAuth2) — contacts, deals, organizations, tasks, notes, pipelines, stages, products, custom fields, sources, campaigns, loss reasons, users, teams and a real webhook trigger.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "rd station",
    "rd station crm",
    "rdstation",
    "crm",
    "sales",
    "pipeline"
  ],
  "license": "MIT",
  "homepage": "https://github.com/PedroHSGuimaraes/n8n-nodes-rd-station-crm#readme",
  "author": {
    "name": "Pedro Henrique Santos Guimarães",
    "email": "pedro.guimaraes02@hotmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroHSGuimaraes/n8n-nodes-rd-station-crm.git"
  },
  "bugs": {
    "url": "https://github.com/PedroHSGuimaraes/n8n-nodes-rd-station-crm/issues"
  },
  "main": "dist/nodes/RdStationCrm/RdStationCrm.node.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RdStationCrmApi.credentials.js",
      "dist/credentials/RdStationCrmOAuth2Api.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RdStationCrm/RdStationCrm.node.js",
      "dist/nodes/RdStationCrmTrigger/RdStationCrmTrigger.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/eslint-plugin-community-nodes": "^0.23.0",
    "@types/node": "^18.19.0",
    "eslint": "^9.29.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^2.16.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.63.0"
  }
}
