{
  "name": "n8n-nodes-rd-station-crm",
  "version": "1.3.1",
  "description": "Nós personalizados do n8n para integração com a API do RD Station CRM (v1)",
  "keywords": [
    "n8n-community-node-package",
    "n8n-nodes-rdstation-crm",
    "n8n-nodes-rd-station-crm",
    "rd station",
    "rd station crm",
    "crm",
    "rd",
    "rdstation",
    "automatização",
    "integração"
  ],
  "license": "MIT",
  "homepage": "https://github.com/PedroHSGuimaraes/n8n-nodes-rd-station-crm#readme",
  "author": {
    "name": "Pedro Henrique Santos Guimarães",
    "email": "pedro.guimaraes02@hotmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PedroHSGuimaraes/n8n-nodes-rd-station-crm.git"
  },
  "bugs": {
    "url": "https://github.com/PedroHSGuimaraes/n8n-nodes-rd-station-crm/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts",
    "lintfix": "eslint . --ext .ts --fix",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "nodes",
    "credentials"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/RdStationCrmApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/RdStationCrmContacts.node.js",
      "dist/nodes/RdStationCrmDeals.node.js",
      "dist/nodes/RdStationCrmTasks.node.js",
      "dist/nodes/RdStationCrmNotes.node.js",
      "dist/nodes/RdStationCrmCompanies.node.js",
      "dist/nodes/RdStationCrmDealProducts.node.js",
      "dist/nodes/RdStationCrmUsers.node.js",
      "dist/nodes/RdStationCrmTeams.node.js",
      "dist/nodes/RdStationCrmPipelines.node.js",
      "dist/nodes/RdStationCrmCampaigns.node.js",
      "dist/nodes/RdStationCrmSources.node.js",
      "dist/nodes/RdStationCrmLossReasons.node.js",
      "dist/nodes/RdStationCrmWebhooks.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.14",
    "@types/gulp": "^4.0.17",
    "@types/node": "^18.19.0",
    "@types/request-promise-native": "~1.0.17",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "eslint": "^8.57.1",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-core": "^0.125.0",
    "n8n-workflow": "^0.107.0",
    "prettier": "^2.7.1",
    "typescript": "~4.7.4"
  },
  "dependencies": {
    "n8n-core": "^0.125.0",
    "request-promise-native": "^1.0.9"
  }
}
